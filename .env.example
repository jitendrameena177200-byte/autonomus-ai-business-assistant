# Rename this file to .env and fill in your own values.
# Never commit your real .env file to GitHub.

# OpenAI API key (required) - https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Chat model used for Q&A, summarization, and the agent
OPENAI_CHAT_MODEL=gpt-4o-mini

# Embedding model used for building the vector store
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Directory containing source business documents (.txt, .pdf, .docx)
DOCUMENTS_DIR=data/documents

# Directory where generated reports/summaries are saved
OUTPUT_DIR=data/outputs

# Directory where the Chroma vector store is persisted
VECTOR_STORE_DIR=data/vector_store

# Company name used in generated reports (customize per client)
COMPANY_NAME=Trident Group
